# Copy to .env to override defaults. All values are optional.

# Allow scanning private / loopback / reserved addresses. Keep "false" in
# production; the SSRF guard blocks internal targets when this is unset.
ALLOW_PRIVATE_TARGETS=false

# Outbound request timeout in seconds.
REQUEST_TIMEOUT=10.0

# Maximum number of redirects to follow (each hop is re-validated).
MAX_REDIRECTS=5

# Cap on response size considered (headers only are read in practice).
MAX_RESPONSE_BYTES=2000000
